  "ASSIGNMENTS": {
    "getByGroup": {
      "method": "GET",
      "url": "/assignments?groupId=:groupId",
      "access": "tutor in session or group member",
      "response_200": { "data": ["...array of assignment objects..."] }
    },
    "create": {
      "method": "POST",
      "url": "/assignments",
      "access": "tutor+",
      "body": "multipart/form-data",
      "fields": {
        "sessionId": "ObjectId (required)",
        "groupId": "ObjectId (required)",
        "courseId": "ObjectId (required)",
        "title": "string (required)",
        "description": "string (optional)",
        "dueAt": "ISO date string (required)",
        "markScale": "'5' | '12' | '100' | 'custom' (required)",
        "maxMark": "number (required)",
        "customOverdueDeduction": "number (optional)",
        "taskFiles": "files (optional, .txt/.pdf/.zip, max 50MB each)"
      },
      "response_201": { "message": "Assignment created", "data": "{ assignment object }" }
    },
    "update": {
      "method": "PATCH",
      "url": "/assignments/:id",
      "access": "tutor in session or manage+",
      "body": "multipart/form-data — same fields as create, all optional",
      "note": "markScale and maxMark can only be changed if no submissions exist yet.",
      "response_200": { "message": "Assignment updated", "data": "{ updated assignment }" }
    },
    "place": {
      "method": "PATCH",
      "url": "/assignments/:id/place",
      "access": "tutor (rank: tutor/professor) or manage+",
      "body": {
        "type": "volume | chapter | item",
        "targetId": "vid / cid / iid string"
      },
      "response_200": { "message": "Assignment placed in course content" }
    },
    "delete": {
      "method": "DELETE",
      "url": "/assignments/:id",
      "access": "host tutor or manage+",
      "response_200": { "message": "Assignment deleted", "data": { "_id": "..." } }
    },
    "removeTaskFile": {
      "method": "DELETE",
      "url": "/assignments/:id/files/:filename",
      "access": "tutor in session or manage+",
      "response_200": { "message": "Task file removed", "data": "{ updated assignment }" }
    },
    "downloadTaskFile": {
      "method": "GET",
      "url": "/assignments/files/:sessionId/:filename",
      "access": "Bearer",
      "response": "Binary file download"
    }
  },

  "SUBMISSIONS": {
    "getSubmissions": {
      "method": "GET",
      "url": "/submissions/:groupId/:assignmentId",
      "access": "Bearer (tutors see all; students see own only)",
      "response_200": { "data": ["...array of submission objects..."] }
    },
    "submit": {
      "method": "POST",
      "url": "/submissions/:groupId/:assignmentId",
      "access": "Bearer (active group member only)",
      "body": "multipart/form-data — field: 'submission' (zip or txt file, max 200MB)",
      "note": "Re-submission only allowed before deadline or if previous was declined.",
      "response_201": {
        "message": "Submitted successfully",
        "data": { "filePath": "...", "isOverdue": false }
      }
    },
    "grade": {
      "method": "PATCH",
      "url": "/submissions/:groupId/:assignmentId/:studentId/grade",
      "access": "host tutor, co-tutor with canGrade, or manage+",
      "body": {
        "mark": 85,
        "feedback": "Good work, but missing edge case handling.",
        "status": "approved"
      },
      "note": "status: 'approved' | 'declined'. Overdue deduction applied automatically if submission.isOverdue and status='approved'.",
      "response_200": {
        "message": "Submission approved",
        "data": { "mark": 83, "overdueDeduction": 2, "wasOverdue": true }
      }
    },
    "downloadSubmission": {
      "method": "GET",
      "url": "/submissions/:groupId/:assignmentId/:studentId/file",
      "access": "Bearer (tutor or the student themselves)",
      "response": "Binary zip file download"
    }
  },

  "FORMS": {
    "submitApplication": {
      "method": "POST",
      "url": "/forms/apply/:formType",
      "access": "public (Bearer optional — attaches userId if present)",
      "body": "multipart/form-data",
      "fields": {
        "data": "JSON string — { firstName, lastName, email, about, ... } (shape depends on formType)",
        "skills": "JSON string — array of skill objects",
        "cert_0": "file — certificate for skills[0]",
        "example_0": "file — example file for skills[0]",
        "cert_1": "file — certificate for skills[1]"
      },
      "formTypes": ["creator", "tutor", "support-ticket"],
      "response_201": { "message": "Submission received", "data": { "_id": "...", "status": "pending" } }
    },
    "getAll": {
      "method": "GET",
      "url": "/forms",
      "access": "quality+ (manage+ recommended)",
      "query": { "formType": "optional filter", "status": "pending|under-review|approved|rejected", "search": "text" },
      "response_200": { "count": 5, "data": ["...array of submission objects..."] }
    },
    "getOneById": {
      "method": "GET",
      "url": "/forms/detail/:id",
      "access": "quality+",
      "response_200": { "data": "{ full submission object }" }
    },
    "updateStatusById": {
      "method": "PATCH",
      "url": "/forms/detail/:id",
      "access": "quality+",
      "body": {
        "status": "approved",
        "reviewNote": "Looks good!"
      },
      "note": "status: 'pending' | 'under-review' | 'approved' | 'rejected'",
      "response_200": { "message": "Submission updated", "data": "{ updated submission }" }
    },
    "deleteById": {
      "method": "DELETE",
      "url": "/forms/detail/:id",
      "access": "quality+",
      "response_200": { "message": "Submission deleted" }
    }
  },

  "FILES": {
    "getCourseFile": {

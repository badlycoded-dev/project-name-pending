  "KEYS": {
    "listAll": {
      "method": "GET",
      "url": "/keys",
      "access": "manage+",
      "response_200": {
        "data": [{
          "_id": "...",
          "code": "ABCDE-FGHIJ-KLMNO",
          "note": "Evening group batch",
          "courses": [{ "_id": "...", "title": "React Course" }],
          "createdBy": "alice",
          "redeemedBy": null,
          "redeemedAt": null,
          "expiresAt": null,
          "createdAt": "...",
          "isRedeemed": false,
          "isExpired": false
        }]
      }
    },
    "generate": {
      "method": "POST",
      "url": "/keys",
      "access": "manage+",
      "body": {
        "courseIds": ["64b5c987e...", "64b5c988f..."],
        "amount": 5,
        "note": "Evening group batch",
        "expiresAt": "2026-12-31T23:59:59.000Z"
      },
      "note": "amount defaults to 1, max 100. expiresAt is optional (null = no expiry).",
      "response_201": {
        "message": "5 key(s) generated",

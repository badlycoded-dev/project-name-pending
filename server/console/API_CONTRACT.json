    },
    "redeem": {
      "method": "POST",
      "url": "/keys/redeem",
      "access": "Bearer",
      "body": { "code": "ABCDE-FGHIJ-KLMNO" },
      "response_200": {
        "message": "Key redeemed — 2 course(s) added to your library",
        "data": {
          "alreadyOwned": 0,
          "newlyUnlocked": 2,
          "courses": [{ "_id": "...", "title": "React Course", "thumbnail": "/api/files/..." }]
        }
      }
    },
    "getMyKeys": {
      "method": "GET",
      "url": "/keys/mine",
      "access": "Bearer",
      "response_200": {
        "data": [{ "_id": "...", "code": "ABCDE-FGHIJ-KLMNO", "courses": [], "redeemedAt": "..." }]
      }
    }
  },

  "PROMOS": {
    "listAll": {
      "method": "GET",
      "url": "/promos",
      "access": "create+ (creators see only their own; manage+ sees all)",
      "response_200": {
        "data": [{
          "_id": "...",
          "code": "LAUNCH20",
          "discountType": "percent",
          "discountValue": 20,
          "courses": [{ "_id": "...", "title": "React Course" }],
          "createdBy": "alice",
          "maxUses": 100,
          "usedCount": 4,
          "expiresAt": null,
          "active": true,
          "isExpired": false,
          "isExhausted": false
        }]
      }
    },
    "create": {
      "method": "POST",
      "url": "/promos",
      "access": "create+",
      "body": {
        "code": "LAUNCH20",
        "courseIds": ["64b5c987e..."],
        "discountType": "percent",
        "discountValue": 20,
        "maxUses": 100,
        "expiresAt": "2026-12-31T23:59:59.000Z",
        "note": "Launch promo"
      },
      "note": "discountType: 'percent' (0-100) or 'flat' (fixed amount). courseIds can be empty array = all courses by creator.",
      "response_201": { "message": "Promo created", "data": { "_id": "...", "code": "LAUNCH20" } }
    },
    "toggle": {
      "method": "PATCH",
      "url": "/promos/:id/toggle",
      "access": "create+ (owner) or manage+",
      "body": {},
      "response_200": { "message": "Promo enabled", "data": { "active": true } }
    },
    "delete": {
      "method": "DELETE",
      "url": "/promos/:id",
      "access": "create+ (owner) or manage+",
      "response_200": { "message": "Promo deleted", "data": { "_id": "..." } }
    },
    "validate": {
      "method": "POST",
      "url": "/promos/validate",
      "access": "Bearer",
      "body": { "code": "LAUNCH20", "courseId": "64b5c987e..." },
      "response_200_valid": {
        "valid": true,
        "code": "LAUNCH20",
        "discountType": "percent",
        "discountValue": 20,
        "originalPrice": 100,
        "discount": 20,
        "finalPrice": 80
      },
      "response_200_invalid": { "valid": false, "reason": "This promo has expired" }
    },
    "apply": {
      "method": "POST",
      "url": "/promos/apply",
      "access": "Bearer",
      "body": { "code": "LAUNCH20", "courseId": "64b5c987e..." },
      "response_200": {
        "message": "Promo applied — course added to your library",
        "data": {
          "courseId": "...",
          "courseTitle": "React Course",
          "originalPrice": 100,
          "discount": 20,
          "finalPrice": 80,
          "alreadyOwned": false
        }
      }
    }
  },

  "SESSIONS": {
    "getAll": {
      "method": "GET",
      "url": "/sessions",
      "access": "tutor+ (tutors see own; manage+ sees all)",
      "response_200": { "data": ["...array of session objects with populated course/tutors..."] }
    },
    "getById": {
      "method": "GET",
      "url": "/sessions/:id",
      "access": "tutor+ (must be host or co-tutor; manage+ unrestricted)",
      "response_200": { "data": "{ full session object }" }
    },
    "create": {
      "method": "POST",
      "url": "/sessions",
      "access": "tutor+",
      "body": {
        "courseId": "64b5c987e...",
        "courseType": "HOSTED",
        "coTutors": [{ "userId": "...", "canGrade": true, "canSchedule": true, "canEditCopy": false }],
        "restrictionIgnored": false
      },
      "note": "courseType defaults to course's own courseType. restrictionIgnored bypasses minTutorRank check (requires manage+ to take effect).",
      "response_201": { "message": "Session created", "data": "{ session object }" }
    },
    "update": {
      "method": "PATCH",
      "url": "/sessions/:id",
      "access": "host tutor or manage+",
      "body": {
        "status": "active",
        "schedule": [{ "title": "Lecture 1", "datetime": "2026-04-01T18:00:00.000Z", "durationMin": 90, "meetingLink": "https://meet.google.com/...", "notes": "", "isRecurring": false }],
        "deadlines": [{ "targetType": "chapter", "targetId": "ch-001", "dueAt": "2026-04-15T23:59:59.000Z", "lockAfterDue": false }],
        "coTutors": [{ "userId": "...", "canGrade": true, "canSchedule": true, "canEditCopy": false }],
        "copyEditAllowed": false,
        "courseType": "HOSTED"
      },
      "note": "Only host or manage+ can update. Send only fields you want to change.",
      "response_200": { "message": "Session updated", "data": "{ updated session }" }
    },
    "delete": {
      "method": "DELETE",
      "url": "/sessions/:id",
      "access": "host tutor or manage+",
      "note": "Session must have status 'completed' before deletion.",
      "response_200": { "message": "Session permanently deleted", "data": { "_id": "...", "groupsDeleted": 2 } }
    },
    "archive": {
      "method": "PATCH",
      "url": "/sessions/:id/archive",
      "access": "host tutor or manage+",
      "body": {},
      "response_200": { "message": "Session archived", "data": { "_id": "..." } }
    },
    "createPrivateCopy": {
      "method": "POST",
      "url": "/sessions/:id/private-copy",
      "access": "host tutor (or co-tutor with canEditCopy) or manage+",
      "body": {},
      "response_201": { "message": "Private copy created (3 file(s) copied)", "data": { "privateCopyId": "..." } }
    },
    "overrideRank": {
      "method": "POST",
      "url": "/sessions/:id/override-rank",
      "access": "host tutor or manage+",
      "body": { "tutorId": "userId of tutor to override" },
      "response_200": { "message": "Rank restriction overridden for tutor ..." }
    },
    "revokeRankOverride": {
      "method": "POST",
      "url": "/sessions/:id/revoke-rank-override",
      "access": "host tutor or manage+",
      "body": { "tutorId": "userId of tutor to revoke" },
      "response_200": { "message": "Rank override revoked for tutor ..." }
    },
    "getExpandedSchedule": {
      "method": "GET",
      "url": "/sessions/:id/schedule/expanded",
      "access": "host or co-tutor or manage+",
      "response_200": { "data": ["...expanded occurrences with occurrenceDate field..."] }
    }
  },


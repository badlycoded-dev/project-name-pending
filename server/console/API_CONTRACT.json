{
  "_meta": {
    "baseUrl": "process.env.REACT_APP_API_URL  →  e.g. http://localhost:4040/api",
    "auth": "All protected routes require header: Authorization: Bearer <token>",
    "tokenStorage": "localStorage.getItem('token')  →  'Bearer eyJ...'",
    "buildAuthHeader": "{ Authorization: token, 'Content-Type': 'application/json' }",
    "note": "Routes marked [public] require no token. All others require Bearer token."
  },

  "AUTH": {
    "login": {
      "method": "POST",
      "url": "/auth/login",
      "access": "public",
      "body": {
        "email": "user@example.com",
        "password": "secret123"
      },
      "response_200": {
        "token": "eyJhbGci...",
        "tokenType": "Bearer"
      }
    },
    "register": {
      "method": "POST",
      "url": "/auth/register",
      "access": "public",
      "body": {
        "email": "user@example.com",
        "password": "secret123",
        "nickname": "alice"
      },
      "response_201": "{ full user document }"
    },
    "validate": {
      "method": "POST",
      "url": "/auth/validate",
      "access": "Bearer token in header",
      "body": {},
      "response_200": { "valid": true },
      "note": "Used to check if the current token has manage+ access. Returns 403 if insufficient."
    },
    "extendSession": {
      "method": "POST",
      "url": "/auth/ext-session",
      "access": "Bearer token in header",
      "body": { "data": "{ any user data object }" },
      "response_200": {
        "token": "eyJhbGci...",
        "tokenType": "Bearer"
      }
    }
  },

  "USERS": {
    "getCurrent": {
      "method": "GET",
      "url": "/users/c",
      "access": "Bearer",
      "response_200": {
        "user": {
          "_id": "...",
          "nickname": "alice",
          "email": "alice@example.com",
          "role": { "_id": "...", "roleName": "admin", "accessLevel": "admin" },
          "tutorRank": null,
          "courses": [],
          "links": []
        }
      }
    },
    "getAll": {
      "method": "GET",
      "url": "/users",
      "access": "public (token optional, affects filtering)",
      "query": {
        "search": "optional string — filters by nickname or email",
        "tutorOnly": "true — returns only users with tutorRank set"
      },
      "response_200": { "data": ["...array of user objects..."] }
    },
    "getById": {
      "method": "GET",
      "url": "/users/:id",
      "access": "public",
      "response_200": { "data": "{ user object with decrypted password token }" }
    },
    "create": {
      "method": "POST",
      "url": "/users",
      "access": "admin+",
      "body": {
        "email": "bob@example.com",
        "password": "secret123",
        "nickname": "bob",
        "role": "roleObjectId"
      },
      "response_201": {
        "message": "User created successfully",
        "login": { "email": "bob@example.com", "password": "secret123" },
        "data": "{ full user document }"
      }
    },
    "update": {
      "method": "PATCH",
      "url": "/users/:id",
      "access": "admin+",
      "body": {
        "nickname": "bob2",
        "firstName": "Bob",
        "lastName": "Smith",
        "email": "bob@example.com",
        "phone": "+380...",
        "github": "bobsmith",
        "role": "roleObjectId",
        "password": "newpass (optional)",
        "courses": []
      },
      "response_200": {
        "message": "User updated successfully",
        "data": "{ updated user }"
      }
    },
    "delete": {
      "method": "DELETE",
      "url": "/users/:id",
      "access": "admin+",
      "response_200": {
        "message": "User deleted successfully",
        "data": { "_id": "..." }
      }
    },
    "finishCourse": {
      "method": "PATCH",
      "url": "/users/me/courses/:courseId/finish",
      "access": "Bearer",
      "body": {},
      "response_200": {
        "message": "Course marked as finished",
        "data": { "process": 1 }
      }
    },
    "uploadProfilePicture": {
      "method": "POST",
      "url": "/users/:id/profile-picture",
      "access": "manage+",
      "body": "multipart/form-data — field name: 'avatar' (image file)",
      "response_200": {
        "message": "Profile picture uploaded successfully",
        "data": { "userId": "...", "filename": "avatar.jpg", "link": { "url": "/api/files/users/:id/avatar.jpg" } }
      }
    },
    "updateProfilePicture": {
      "method": "PUT",
      "url": "/users/:id/profile-picture",
      "access": "manage+",
      "body": "multipart/form-data — field name: 'avatar' (image file)",
      "response_200": {
        "message": "Profile picture updated successfully",
        "data": { "userId": "...", "filename": "avatar.jpg", "link": {} }
      }
    },
    "deleteProfilePicture": {
      "method": "DELETE",
      "url": "/users/:id/profile-picture",
      "access": "manage+",
      "response_200": {
        "message": "Profile picture deleted successfully",
        "data": { "userId": "..." }
      }
    },
    "getProfilePicture": {
      "method": "GET",
      "url": "/users/:id/profile-picture/:filename",
      "access": "public",
      "response": "Binary image file"
    }
  },

  "COURSES": {
    "getAll": {
      "method": "GET",
      "url": "/courses",
      "access": "public",
      "response_200": { "data": ["...array of course objects..."] }
    },
    "getById": {
      "method": "GET",
      "url": "/courses/:id",
      "access": "public",
      "response_200": { "data": "{ full course object }" }
    },
    "create": {
      "method": "POST",
      "url": "/courses",
      "access": "create+",
      "body": {
        "direction": "Web Development",
        "level": "Beginner",
        "price": 0,
        "base_lang": "en",
        "courseType": "SELF_TAUGHT",
        "trans": [{ "title": "My Course", "description": "About this course", "skills": [] }],
        "volumes": [],
        "links": []
      },
      "response_201": { "message": "Course created successfully", "data": "{ course }" }
    },
    "update": {
      "method": "PUT or PATCH",
      "url": "/courses/:id",
      "access": "create+",
      "body": "Same shape as create — all fields optional in PATCH",
      "response_200": { "message": "Course updated successfully", "data": "{ course }" }
    },
    "delete": {
      "method": "DELETE",
      "url": "/courses/:id",
      "access": "create+",
      "response_200": { "message": "Course deleted successfully", "data": { "_id": "..." } }
    },
    "getRating": {
      "method": "GET",
      "url": "/courses/:id/rating",
      "access": "Bearer",
      "response_200": { "data": { "myRating": 4, "averageRating": 4.2 } }
    },
    "rateById": {
      "method": "POST",
      "url": "/courses/:id/rating",
      "access": "Bearer",
      "body": { "value": 5 },
      "response_200": { "message": "Rating submitted", "data": { "averageRating": 4.3 } }
    },
    "getComments": {
      "method": "GET",
      "url": "/courses/:id/comments",
      "access": "public",
      "response_200": { "data": [{ "_id": "...", "userId": "...", "text": "Great course!", "date": "..." }] }
    },
    "addComment": {
      "method": "POST",
      "url": "/courses/:id/comments",
      "access": "Bearer",
      "body": { "text": "Great course!" },
      "response_201": { "message": "Comment added", "data": "{ comment }" }
    },
    "deleteComment": {
      "method": "DELETE",
      "url": "/courses/:id/comments/:commentId",
      "access": "Bearer",
      "response_200": { "message": "Comment deleted" }
    },
    "listFiles": {
      "method": "GET",
      "url": "/courses/:id/files",
      "access": "public",
      "response_200": {
        "courseId": "...",
        "count": 3,
        "files": [{ "filename": "lecture1.pdf", "size": 12345, "url": "/api/files/courses/:id/lecture1.pdf" }]
      }
    },
    "getFile": {
      "method": "GET",
      "url": "/courses/:id/files/:filename",
      "access": "public",
      "query": { "download": "true — forces download disposition" },
      "response": "Binary file"
    },
    "uploadFile": {
      "method": "POST",
      "url": "/courses/:id/files",
      "access": "create+",
      "body": "multipart/form-data — field: 'file'; optional query: ?thumbnail=true",
      "response_201": { "message": "File uploaded", "data": { "url": "/api/files/courses/:id/filename.jpg", "filename": "..." } }
    },
    "uploadMultipleFiles": {
      "method": "POST",
      "url": "/courses/:id/files/multiple",
      "access": "create+",
      "body": "multipart/form-data — field: 'files' (multiple)",
      "response_201": { "message": "Files uploaded", "data": [{ "url": "...", "filename": "..." }] }
    },
    "deleteFile": {
      "method": "DELETE",
      "url": "/courses/:id/files/:filename",
      "access": "create+",
      "response_200": { "message": "File deleted successfully", "data": { "courseId": "...", "filename": "..." } }
    }
  },


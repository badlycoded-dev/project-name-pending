# Copy to .env and fill in real values — never commit .env to git

# Must match your main app's JWT_SECRET exactly
JWT_SECRET=Z3H@u8E#375Q[hKxAprDFGmERb05

# Origins allowed to connect (comma-separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000

# Optional: MongoDB URI for persistent room settings
# MONGO_URI=mongodb://mongo:27017/yourdb

# TURN credentials (must match coturn/turnserver.conf)
TURN_USERNAME=rtcuser
TURN_CREDENTIAL=changeme

# Public IP of your server (required for coturn in production)
# COTURN_EXTERNAL_IP=1.2.3.4

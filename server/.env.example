# ═══════════════════════════════════════════════════════════════════════════════
# .env.example - Template for deployment
# ═══════════════════════════════════════════════════════════════════════════════
#
# NEVER commit .env to git (it contains secrets)!
# Instead: copy this file and configure your own
#
#   For LOCAL testing:
#       Copy to: .env.local (used by docker-compose.local.yml)
#
#   For PRODUCTION:
#       Copy to: .env (used by docker-compose.yml)
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ────────────────────────────────────────────────────
# Your server's public domain or IP (required)
SERVER_HOST=178.151.253.45

# Enable HTTPS with Let's Encrypt (true) or plain HTTP (false)
USE_HTTPS=true

# ─── Ports ──────────────────────────────────────────────────────────────────
API_PORT_HTTP=4040
RTC_PORT_HTTP=5050
WEB_PORT_HTTP=4000

API_PORT_HTTPS=4043
RTC_PORT_HTTPS=5051
WEB_PORT_HTTPS=4004

# ─── Database (MongoDB) ─────────────────────────────────────────────────────
DB_NAME=P_01
DB_DRIVER=mongo
DB_URL=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# ─── JWT & Security ──────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=14400

# ─── RTC / TURN (for video conferencing) ────────────────────────────────────
STUN_URLS=stun:coturn:3478
TURN_URL=turn:coturn:3478
TURN_USERNAME=rtcuser
TURN_CREDENTIAL=changeme

# ─── Email (EmailJS) ────────────────────────────────────────────────────────
REACT_APP_EMAILJS_PUBLIC_KEY=your-emailjs-key

# ─── Node Environment ──────────────────────────────────────────────────────
NODE_ENV=production
NODE_TLS_REJECT_UNAUTHORIZED=0

# ─── Frontend URLs (auto-computed from SERVER_HOST) ────────────────────────
REACT_APP_API_URL=https://your-domain.com:4043/api
REACT_APP_RTC_URL=https://your-domain.com:5051
REACT_APP_USE_HTTPS=true

# ─── Let's Encrypt (for automatic SSL renewal) ─────────────────────────────
# Email for certificate renewal notifications
ACME_EMAIL=admin@your-domain.com

{
  "_meta": {
    "version": "2.0",
    "baseUrl": "http://<host>:4040/api",
    "description": "All endpoints are relative to baseUrl. Set via REACT_APP_API_URL env var.",
    "auth": {
      "type": "Bearer JWT",
      "header": "Authorization: Bearer <token>",
      "storage": "localStorage key: 'token'  →  value: 'Bearer eyJ...'",
      "obtain": "POST /auth/login",
      "note": "Routes marked 'public' work without a token. All others return 401 if token is missing or invalid."
    },
    "accessLevels": {
      "public":  "No token required",
      "Bearer":  "Any valid token",
      "tutor+":  "accessLevel: tutor, professor, create, manage, quality, admin",
      "create+": "accessLevel: create, manage, quality, admin",
      "manage+": "accessLevel: manage, quality, admin",
      "quality+":"accessLevel: quality, admin",
      "admin+":  "accessLevel: admin only"
    },
    "errors": {
      "400": "Bad request / validation error  →  { message: string }",
      "401": "Missing or invalid token",
      "403": "Insufficient access level",
      "404": "Resource not found  →  { message: string }",
      "500": "Internal server error  →  { message: string }"
    }
  },

  "AUTH": {
    "login": {
      "method": "POST",
      "path": "/auth/login",
      "access": "public",
      "body": { "email": "string", "password": "string" },
      "response_200": { "token": "Bearer eyJ...", "tokenType": "Bearer" }
    },
    "register": {
      "method": "POST",
      "path": "/auth/register",
      "access": "public",
      "body": { "email": "string", "password": "string", "nickname": "string" },
      "response_201": { "_id": "ObjectId", "email": "string", "nickname": "string" }
    },
    "validate": {
      "method": "POST",
      "path": "/auth/validate",
      "access": "manage+",
      "body": {},
      "response_200": { "valid": true },
      "note": "Checks that the current token has at least manage-level access. Returns 403 if insufficient."
    },
    "extendSession": {
      "method": "POST",
      "path": "/auth/ext-session",
      "access": "Bearer",
      "body": { "data": "object — any user data to embed in the new token" },
      "response_200": { "token": "Bearer eyJ...", "tokenType": "Bearer" }
    }
  },

  "USERS": {
    "getCurrent": {
      "method": "GET",
      "path": "/users/c",
      "access": "Bearer",
      "response_200": {
        "user": {
          "_id": "ObjectId",
          "nickname": "string",
          "email": "string",
          "firstName": "string|null",
          "lastName": "string|null",
          "phone": "string|null",
          "github": "string|null",
          "role": { "_id": "ObjectId", "roleName": "string", "accessLevel": "string" },
          "tutorRank": "string|null",
          "courses": ["ObjectId"],
          "links": ["object"]
        }
      }
    },
    "updateCourseProgress": {
      "method": "PATCH",
      "path": "/users/me/courses/:courseId/progress",
      "access": "Bearer",
      "body": { "itemId": "string", "chapterId": "string", "volumeId": "string" },
      "response_200": { "message": "Progress updated", "data": { "progress": "object" } }
    },
    "finishCourse": {
      "method": "PATCH",
      "path": "/users/me/courses/:courseId/finish",
      "access": "Bearer",
      "body": {},
      "response_200": { "message": "Course marked as finished", "data": { "process": 1 } }
    },
    "getAll": {
      "method": "GET",
      "path": "/users",
      "access": "public",
      "query": {
        "search": "string — filter by nickname or email (optional)",
        "tutorOnly": "true — return only users with tutorRank set (optional)"
      },
      "response_200": { "data": ["...user objects..."] }
    },
    "getById": {
      "method": "GET",
      "path": "/users/:id",
      "access": "public",
      "response_200": { "data": { "...": "full user object" } }
    },
    "create": {
      "method": "POST",
      "path": "/users",
      "access": "admin+",
      "body": {
        "email": "string (required)",
        "password": "string (required)",
        "nickname": "string (required)",
        "role": "ObjectId (required)"
      },
      "response_201": {
        "message": "User created successfully",
        "login": { "email": "string", "password": "string" },
        "data": { "...": "full user object" }
      }
    },
    "update": {
      "method": "PATCH",
      "path": "/users/:id",
      "access": "admin+",
      "body": {
        "nickname": "string (optional)",
        "firstName": "string (optional)",
        "lastName": "string (optional)",
        "email": "string (optional)",
        "phone": "string (optional)",
        "github": "string (optional)",
        "role": "ObjectId (optional)",
        "password": "string (optional)",
        "courses": "ObjectId[] (optional)"
      },
      "response_200": { "message": "User updated successfully", "data": { "...": "updated user" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/users/:id",
      "access": "admin+",
      "response_200": { "message": "User deleted successfully", "data": { "_id": "ObjectId" } }
    },
    "getProfilePicture": {
      "method": "GET",
      "path": "/users/:id/profile-picture/:filename",
      "access": "public",
      "response": "Binary image file"
    },
    "uploadProfilePicture": {
      "method": "POST",
      "path": "/users/:id/profile-picture",
      "access": "manage+",
      "body": "multipart/form-data — field: avatar (image file)",
      "response_200": { "message": "Profile picture uploaded successfully", "data": { "userId": "ObjectId", "filename": "string", "link": { "url": "string" } } }
    },
    "updateProfilePicture": {
      "method": "PUT",
      "path": "/users/:id/profile-picture",
      "access": "manage+",
      "body": "multipart/form-data — field: avatar (image file)",
      "response_200": { "message": "Profile picture updated successfully", "data": { "userId": "ObjectId", "filename": "string" } }
    },
    "deleteProfilePicture": {
      "method": "DELETE",
      "path": "/users/:id/profile-picture",
      "access": "manage+",
      "response_200": { "message": "Profile picture deleted successfully", "data": { "userId": "ObjectId" } }
    }
  },

  "COURSES": {
    "getAll": {
      "method": "GET",
      "path": "/courses",
      "access": "public",
      "response_200": { "data": ["...course objects..."] }
    },
    "getById": {
      "method": "GET",
      "path": "/courses/:id",
      "access": "public",
      "response_200": { "data": { "...": "full course object" } }
    },
    "create": {
      "method": "POST",
      "path": "/courses",
      "access": "create+",
      "body": {
        "direction": "string (required)",
        "level": "string (required)",
        "price": "number (required)",
        "base_lang": "string (required)",
        "courseType": "SELF_TAUGHT | HOSTED (required)",
        "trans": [{ "title": "string", "description": "string", "skills": [] }],
        "volumes": "array (optional)",
        "links": "array (optional)"
      },
      "response_201": { "message": "Course created successfully", "data": { "...": "course object" } }
    },
    "update": {
      "method": "PATCH",
      "path": "/courses/:id",
      "access": "create+",
      "body": "Same shape as create — all fields optional",
      "response_200": { "message": "Course updated successfully", "data": { "...": "updated course" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/courses/:id",
      "access": "create+",
      "response_200": { "message": "Course deleted successfully", "data": { "_id": "ObjectId" } }
    },
    "getRating": {
      "method": "GET",
      "path": "/courses/:id/rating",
      "access": "Bearer",
      "response_200": { "data": { "myRating": "number|null", "averageRating": "number" } }
    },
    "submitRating": {
      "method": "POST",
      "path": "/courses/:id/rating",
      "access": "Bearer",
      "body": { "value": "number 1–5" },
      "response_200": { "message": "Rating submitted", "data": { "averageRating": "number" } }
    },
    "getComments": {
      "method": "GET",
      "path": "/courses/:id/comments",
      "access": "public",
      "response_200": { "data": [{ "_id": "ObjectId", "userId": "ObjectId", "text": "string", "date": "ISO date" }] }
    },
    "addComment": {
      "method": "POST",
      "path": "/courses/:id/comments",
      "access": "Bearer",
      "body": { "text": "string" },
      "response_201": { "message": "Comment added", "data": { "...": "comment object" } }
    },
    "deleteComment": {
      "method": "DELETE",
      "path": "/courses/:id/comments/:commentId",
      "access": "Bearer",
      "response_200": { "message": "Comment deleted" }
    },
    "listFiles": {
      "method": "GET",
      "path": "/courses/:id/files",
      "access": "public",
      "response_200": {
        "courseId": "ObjectId",
        "count": "number",
        "files": [{ "filename": "string", "size": "number (bytes)", "url": "/api/files/courses/:id/filename" }]
      }
    },
    "getFile": {
      "method": "GET",
      "path": "/courses/:id/files/:filename",
      "access": "public",
      "query": { "download": "true — forces Content-Disposition: attachment (optional)" },
      "response": "Binary file"
    },
    "uploadFile": {
      "method": "POST",
      "path": "/courses/:id/files",
      "access": "create+",
      "body": "multipart/form-data — field: file",
      "query": { "thumbnail": "true — marks this file as the course thumbnail (optional)" },
      "response_201": { "message": "File uploaded", "data": { "url": "string", "filename": "string" } }
    },
    "uploadMultipleFiles": {
      "method": "POST",
      "path": "/courses/:id/files/multiple",
      "access": "create+",
      "body": "multipart/form-data — field: files (multiple)",
      "response_201": { "message": "Files uploaded", "data": [{ "url": "string", "filename": "string" }] }
    },
    "deleteFile": {
      "method": "DELETE",
      "path": "/courses/:id/files/:filename",
      "access": "create+",
      "response_200": { "message": "File deleted successfully", "data": { "courseId": "ObjectId", "filename": "string" } }
    }
  },

  "DIRECTIONS": {
    "getAll": {
      "method": "GET",
      "path": "/directions",
      "access": "public",
      "response_200": { "data": [{ "_id": "ObjectId", "directionName": "string" }] }
    },
    "getById": {
      "method": "GET",
      "path": "/directions/:id",
      "access": "public",
      "response_200": { "data": { "_id": "ObjectId", "directionName": "string" } }
    },
    "create": {
      "method": "POST",
      "path": "/directions",
      "access": "manage+",
      "body": { "directionName": "string (required)" },
      "response_201": { "message": "Direction created successfully", "data": { "_id": "ObjectId", "directionName": "string" } }
    },
    "update": {
      "method": "PUT",
      "path": "/directions/:id",
      "access": "manage+",
      "body": { "directionName": "string (required)" },
      "response_200": { "message": "Direction updated successfully", "data": { "_id": "ObjectId", "directionName": "string" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/directions/:id",
      "access": "manage+",
      "response_200": { "message": "Direction deleted successfully", "data": { "_id": "ObjectId" } }
    }
  },

  "LEVELS": {
    "getAll": {
      "method": "GET",
      "path": "/levels",
      "access": "public",
      "response_200": { "data": [{ "_id": "ObjectId", "levelName": "string", "directionName": "string", "minTutorRank": "string" }] }
    },
    "getById": {
      "method": "GET",
      "path": "/levels/:id",
      "access": "public",
      "response_200": { "data": { "_id": "ObjectId", "levelName": "string", "directionName": "string", "minTutorRank": "string" } }
    },
    "create": {
      "method": "POST",
      "path": "/levels",
      "access": "manage+",
      "body": {
        "levelName": "string (required)",
        "directionName": "string (required)",
        "minTutorRank": "assistant | tutor | teacher | professor (required)"
      },
      "response_201": { "message": "Level created successfully", "data": { "_id": "ObjectId", "levelName": "string" } }
    },
    "update": {
      "method": "PUT",
      "path": "/levels/:id",
      "access": "manage+",
      "body": {
        "levelName": "string (optional)",
        "directionName": "string (optional)",
        "minTutorRank": "string (optional)"
      },
      "response_200": { "message": "Level updated successfully", "data": { "_id": "ObjectId", "levelName": "string" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/levels/:id",
      "access": "manage+",
      "response_200": { "message": "Level deleted successfully", "data": { "_id": "ObjectId" } }
    }
  },

  "ROLES": {
    "getAll": {
      "method": "GET",
      "path": "/roles",
      "access": "manage+",
      "response_200": { "data": [{ "_id": "ObjectId", "roleName": "string", "accessLevel": "string" }] }
    },
    "getById": {
      "method": "GET",
      "path": "/roles/:id",
      "access": "manage+",
      "response_200": { "data": { "_id": "ObjectId", "roleName": "string", "accessLevel": "string" } }
    },
    "create": {
      "method": "POST",
      "path": "/roles",
      "access": "manage+",
      "body": { "roleName": "string (required)", "accessLevel": "string (required)" },
      "response_201": { "message": "Role created successfully", "data": { "_id": "ObjectId", "roleName": "string" } }
    },
    "update": {
      "method": "PUT",
      "path": "/roles/:id",
      "access": "manage+",
      "body": { "roleName": "string (optional)", "accessLevel": "string (optional)" },
      "response_200": { "message": "Role updated successfully", "data": { "_id": "ObjectId", "roleName": "string" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/roles/:id",
      "access": "manage+",
      "response_200": { "message": "Role deleted successfully", "data": { "_id": "ObjectId" } }
    }
  },

  "KEYS": {
    "listAll": {
      "method": "GET",
      "path": "/keys",
      "access": "manage+",
      "response_200": {
        "data": [{
          "_id": "ObjectId",
          "code": "XXXXX-XXXXX-XXXXX",
          "note": "string|null",
          "courses": [{ "_id": "ObjectId", "title": "string" }],
          "createdBy": "string (nickname)",
          "redeemedBy": "string|null",
          "redeemedAt": "ISO date|null",
          "expiresAt": "ISO date|null",
          "createdAt": "ISO date",
          "isRedeemed": "boolean",
          "isExpired": "boolean"
        }]
      }
    },
    "generate": {
      "method": "POST",
      "path": "/keys",
      "access": "manage+",
      "body": {
        "courseIds": "ObjectId[] (required)",
        "amount": "number 1–100 (optional, default 1)",
        "note": "string (optional)",
        "expiresAt": "ISO date (optional — null means no expiry)"
      },
      "response_201": { "message": "N key(s) generated", "data": [{ "_id": "ObjectId", "code": "string" }] }
    },
    "delete": {
      "method": "DELETE",
      "path": "/keys/:id",
      "access": "manage+",
      "note": "Cannot delete already-redeemed keys.",
      "response_200": { "message": "Key deleted", "data": { "_id": "ObjectId" } }
    },
    "redeem": {
      "method": "POST",
      "path": "/keys/redeem",
      "access": "Bearer",
      "body": { "code": "string (required)" },
      "response_200": {
        "message": "Key redeemed — N course(s) added to your library",
        "data": {
          "alreadyOwned": "number",
          "newlyUnlocked": "number",
          "courses": [{ "_id": "ObjectId", "title": "string", "thumbnail": "string|null" }]
        }
      }
    },
    "getMyKeys": {
      "method": "GET",
      "path": "/keys/mine",
      "access": "Bearer",
      "response_200": { "data": [{ "_id": "ObjectId", "code": "string", "courses": [], "redeemedAt": "ISO date" }] }
    }
  },

  "PROMOS": {
    "listAll": {
      "method": "GET",
      "path": "/promos",
      "access": "create+ (creators see own only; manage+ sees all)",
      "response_200": {
        "data": [{
          "_id": "ObjectId",
          "code": "string",
          "discountType": "percent | flat",
          "discountValue": "number",
          "courses": [{ "_id": "ObjectId", "title": "string" }],
          "createdBy": "string (nickname)",
          "maxUses": "number|null",
          "usedCount": "number",
          "expiresAt": "ISO date|null",
          "active": "boolean",
          "isExpired": "boolean",
          "isExhausted": "boolean"
        }]
      }
    },
    "create": {
      "method": "POST",
      "path": "/promos",
      "access": "create+",
      "body": {
        "code": "string (required)",
        "courseIds": "ObjectId[] (required — empty array = all courses by this creator)",
        "discountType": "percent | flat (required)",
        "discountValue": "number (required — percent: 0–100, flat: fixed amount)",
        "maxUses": "number (optional — null = unlimited)",
        "expiresAt": "ISO date (optional — null = no expiry)",
        "note": "string (optional)"
      },
      "response_201": { "message": "Promo created", "data": { "_id": "ObjectId", "code": "string" } }
    },
    "toggle": {
      "method": "PATCH",
      "path": "/promos/:id/toggle",
      "access": "create+ (owner) or manage+",
      "body": {},
      "response_200": { "message": "Promo enabled|disabled", "data": { "active": "boolean" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/promos/:id",
      "access": "create+ (owner) or manage+",
      "response_200": { "message": "Promo deleted", "data": { "_id": "ObjectId" } }
    },
    "validate": {
      "method": "POST",
      "path": "/promos/validate",
      "access": "Bearer",
      "body": { "code": "string (required)", "courseId": "ObjectId (required)" },
      "response_200_valid": {
        "valid": true,
        "code": "string",
        "discountType": "percent | flat",
        "discountValue": "number",
        "originalPrice": "number",
        "discount": "number",
        "finalPrice": "number"
      },
      "response_200_invalid": { "valid": false, "reason": "string" }
    },
    "apply": {
      "method": "POST",
      "path": "/promos/apply",
      "access": "Bearer",
      "body": { "code": "string (required)", "courseId": "ObjectId (required)" },
      "response_200": {
        "message": "Promo applied — course added to your library",
        "data": {
          "courseId": "ObjectId",
          "courseTitle": "string",
          "originalPrice": "number",
          "discount": "number",
          "finalPrice": "number",
          "alreadyOwned": "boolean"
        }
      }
    }
  },

  "SESSIONS": {
    "getAll": {
      "method": "GET",
      "path": "/sessions",
      "access": "tutor+ (tutors see own sessions; manage+ sees all)",
      "response_200": { "data": ["...session objects populated with course and tutors..."] }
    },
    "getById": {
      "method": "GET",
      "path": "/sessions/:id",
      "access": "tutor+ (must be host or co-tutor; manage+ unrestricted)",
      "response_200": { "data": { "...": "full session object" } }
    },
    "create": {
      "method": "POST",
      "path": "/sessions",
      "access": "tutor+",
      "body": {
        "courseId": "ObjectId (required)",
        "courseType": "SELF_TAUGHT | HOSTED (optional — defaults to course's courseType)",
        "coTutors": [{ "userId": "ObjectId", "canGrade": "boolean", "canSchedule": "boolean", "canEditCopy": "boolean" }],
        "restrictionIgnored": "boolean (optional — bypasses minTutorRank check, requires manage+)"
      },
      "response_201": { "message": "Session created", "data": { "...": "session object" } }
    },
    "update": {
      "method": "PATCH",
      "path": "/sessions/:id",
      "access": "host tutor or manage+",
      "body": {
        "status": "draft | active | completed (optional)",
        "schedule": [{
          "title": "string",
          "datetime": "ISO date",
          "durationMin": "number",
          "meetingLink": "string (optional)",
          "notes": "string (optional)",
          "isRecurring": "boolean"
        }],
        "deadlines": [{ "targetType": "chapter | volume | item", "targetId": "string", "dueAt": "ISO date", "lockAfterDue": "boolean" }],
        "coTutors": [{ "userId": "ObjectId", "canGrade": "boolean", "canSchedule": "boolean", "canEditCopy": "boolean" }],
        "copyEditAllowed": "boolean (optional)",
        "courseType": "SELF_TAUGHT | HOSTED (optional)"
      },
      "note": "Send only the fields you want to change.",
      "response_200": { "message": "Session updated", "data": { "...": "updated session" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/sessions/:id",
      "access": "host tutor or manage+",
      "note": "Session must have status 'completed' before deletion.",
      "response_200": { "message": "Session permanently deleted", "data": { "_id": "ObjectId", "groupsDeleted": "number" } }
    },
    "archive": {
      "method": "PATCH",
      "path": "/sessions/:id/archive",
      "access": "host tutor or manage+",
      "body": {},
      "response_200": { "message": "Session archived", "data": { "_id": "ObjectId" } }
    },
    "createPrivateCopy": {
      "method": "POST",
      "path": "/sessions/:id/private-copy",
      "access": "host tutor, co-tutor with canEditCopy, or manage+",
      "body": {},
      "response_201": { "message": "Private copy created (N file(s) copied)", "data": { "privateCopyId": "ObjectId" } }
    },
    "overrideRank": {
      "method": "POST",
      "path": "/sessions/:id/override-rank",
      "access": "host tutor or manage+",
      "body": { "tutorId": "ObjectId (required)" },
      "response_200": { "message": "Rank restriction overridden for tutor <nickname>" }
    },
    "revokeRankOverride": {
      "method": "POST",
      "path": "/sessions/:id/revoke-rank-override",
      "access": "host tutor or manage+",
      "body": { "tutorId": "ObjectId (required)" },
      "response_200": { "message": "Rank override revoked for tutor <nickname>" }
    },
    "getExpandedSchedule": {
      "method": "GET",
      "path": "/sessions/:id/schedule/expanded",
      "access": "host, co-tutor, or manage+",
      "response_200": { "data": ["...expanded schedule entries with occurrenceDate field..."] }
    }
  },

  "GROUPS": {
    "getMyGroups": {
      "method": "GET",
      "path": "/groups/my",
      "access": "Bearer",
      "response_200": { "data": ["...groups where the current user is a member..."] }
    },
    "getBySession": {
      "method": "GET",
      "path": "/groups",
      "access": "tutor in session or manage+",
      "query": { "sessionId": "ObjectId (required)" },
      "response_200": { "data": ["...group objects with populated members and assignments..."] }
    },
    "getById": {
      "method": "GET",
      "path": "/groups/:id",
      "access": "Bearer (tutor in session, group member, or manage+)",
      "response_200": { "data": { "...": "full group object" } }
    },
    "create": {
      "method": "POST",
      "path": "/groups",
      "access": "tutor in session or manage+",
      "body": { "sessionId": "ObjectId (required)", "name": "string (required)" },
      "response_201": { "message": "Group created", "data": { "...": "group object" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/groups/:id",
      "access": "host tutor or manage+",
      "response_200": { "message": "Group deleted", "data": { "_id": "ObjectId" } }
    },
    "addMember": {
      "method": "POST",
      "path": "/groups/:id/members",
      "access": "tutor in session or manage+",
      "body": { "emailOrNickname": "string (required)" },
      "response_200": { "message": "<nickname> added to group", "data": { "userId": "ObjectId", "nickname": "string" } }
    },
    "updateMemberStatus": {
      "method": "PATCH",
      "path": "/groups/:id/members/:userId/status",
      "access": "tutor in session or manage+",
      "body": { "status": "active | dropped | completed (required)" },
      "response_200": { "message": "Member status updated" }
    },
    "removeMember": {
      "method": "DELETE",
      "path": "/groups/:id/members/:userId",
      "access": "tutor in session or manage+",
      "response_200": { "message": "Member removed from group" }
    }
  },

  "ASSIGNMENTS": {
    "getByGroup": {
      "method": "GET",
      "path": "/assignments",
      "access": "tutor in session or group member",
      "query": { "groupId": "ObjectId (required)" },
      "response_200": { "data": ["...assignment objects..."] }
    },
    "create": {
      "method": "POST",
      "path": "/assignments",
      "access": "tutor+",
      "body": "multipart/form-data",
      "fields": {
        "sessionId": "ObjectId (required)",
        "groupId": "ObjectId (required)",
        "courseId": "ObjectId (required)",
        "title": "string (required)",
        "description": "string (optional)",
        "dueAt": "ISO date (required)",
        "markScale": "5 | 12 | 100 | custom (required)",
        "maxMark": "number (required)",
        "customOverdueDeduction": "number (optional)",
        "taskFiles": "files — .txt/.pdf/.zip, max 50MB each (optional)"
      },
      "response_201": { "message": "Assignment created", "data": { "...": "assignment object" } }
    },
    "update": {
      "method": "PATCH",
      "path": "/assignments/:id",
      "access": "tutor in session or manage+",
      "body": "multipart/form-data — same fields as create, all optional",
      "note": "markScale and maxMark can only be changed if no submissions exist for this assignment yet.",
      "response_200": { "message": "Assignment updated", "data": { "...": "updated assignment" } }
    },
    "place": {
      "method": "PATCH",
      "path": "/assignments/:id/place",
      "access": "tutor (rank: tutor or professor) or manage+",
      "body": {
        "type": "volume | chapter | item (required)",
        "targetId": "string — vid / cid / iid (required)"
      },
      "response_200": { "message": "Assignment placed in course content" }
    },
    "delete": {
      "method": "DELETE",
      "path": "/assignments/:id",
      "access": "host tutor or manage+",
      "response_200": { "message": "Assignment deleted", "data": { "_id": "ObjectId" } }
    },
    "removeTaskFile": {
      "method": "DELETE",
      "path": "/assignments/:id/files/:filename",
      "access": "tutor in session or manage+",
      "response_200": { "message": "Task file removed", "data": { "...": "updated assignment" } }
    },
    "downloadTaskFile": {
      "method": "GET",
      "path": "/assignments/files/:sessionId/:filename",
      "access": "Bearer",
      "response": "Binary file download"
    }
  },

  "SUBMISSIONS": {
    "getSubmissions": {
      "method": "GET",
      "path": "/submissions/:groupId/:assignmentId",
      "access": "Bearer (tutors see all; students see own only)",
      "response_200": { "data": ["...submission objects..."] }
    },
    "submit": {
      "method": "POST",
      "path": "/submissions/:groupId/:assignmentId",
      "access": "Bearer (active group member only)",
      "body": "multipart/form-data — field: submission (.zip or .txt, max 200MB)",
      "note": "Re-submission allowed only before deadline or if previous submission was declined.",
      "response_201": { "message": "Submitted successfully", "data": { "filePath": "string", "isOverdue": "boolean" } }
    },
    "grade": {
      "method": "PATCH",
      "path": "/submissions/:groupId/:assignmentId/:studentId/grade",
      "access": "host tutor, co-tutor with canGrade, or manage+",
      "body": {
        "mark": "number (required)",
        "feedback": "string (optional)",
        "status": "approved | declined (required)"
      },
      "note": "If submission.isOverdue and status='approved', overdue deduction is applied automatically.",
      "response_200": { "message": "Submission approved|declined", "data": { "mark": "number", "overdueDeduction": "number", "wasOverdue": "boolean" } }
    },
    "downloadSubmission": {
      "method": "GET",
      "path": "/submissions/:groupId/:assignmentId/:studentId/file",
      "access": "Bearer (the submitting student or a tutor in the session)",
      "response": "Binary zip file download"
    }
  },

  "FORMS": {
    "submitApplication": {
      "method": "POST",
      "path": "/forms/apply/:formType",
      "access": "public (Bearer optional — attaches userId if present)",
      "params": { "formType": "creator | tutor | support-ticket" },
      "body": "multipart/form-data",
      "fields": {
        "data": "JSON string — { firstName, lastName, email, about, ... } shape depends on formType",
        "skills": "JSON string — array of skill objects",
        "cert_N": "file — certificate for skills[N]",
        "example_N": "file — example file for skills[N]"
      },
      "response_201": { "message": "Submission received", "data": { "_id": "ObjectId", "status": "pending" } }
    },
    "getAll": {
      "method": "GET",
      "path": "/forms",
      "access": "quality+",
      "query": {
        "formType": "creator | tutor | support-ticket (optional)",
        "status": "pending | under-review | approved | rejected (optional)",
        "search": "string (optional)"
      },
      "response_200": { "count": "number", "data": ["...submission objects..."] }
    },
    "getById": {
      "method": "GET",
      "path": "/forms/detail/:id",
      "access": "quality+",
      "response_200": { "data": { "...": "full submission object" } }
    },
    "updateStatus": {
      "method": "PATCH",
      "path": "/forms/detail/:id",
      "access": "quality+",
      "body": {
        "status": "pending | under-review | approved | rejected (required)",
        "reviewNote": "string (optional)"
      },
      "response_200": { "message": "Submission updated", "data": { "...": "updated submission" } }
    },
    "delete": {
      "method": "DELETE",
      "path": "/forms/detail/:id",
      "access": "quality+",
      "response_200": { "message": "Submission deleted" }
    }
  },

  "FILES": {
    "getCourseFile": {
      "method": "GET",
      "path": "/files/courses/:courseId/:filename",
      "access": "public",
      "query": { "download": "true — forces Content-Disposition: attachment (optional)" },
      "response": "Binary file"
    },
    "getUserFile": {
      "method": "GET",
      "path": "/files/users/:userId/:filename",
      "access": "public",
      "response": "Binary image"
    },
    "getFormFile": {
      "method": "GET",
      "path": "/files/forms/:formType/:id/:subdir/:filename",
      "access": "Bearer",
      "response": "Binary file"
    }
  },

  "UTILS": {
    "status": {
      "method": "GET",
      "path": "/utils/status",
      "access": "manage+",
      "response_200": {
        "status": "online",
        "uptime": "number (seconds)",
        "launchTime": "ISO date",
        "db_status": "connected | reconnecting | disconnected",
        "courses": [],
        "users": []
      }
    },
    "statusStream": {
      "method": "GET",
      "path": "/utils/status/stream",
      "access": "token as query param",
      "query": { "token": "Bearer eyJ... (required — full token string including 'Bearer ' prefix)" },
      "note": "Server-Sent Events. Pushes a status snapshot every 5 seconds.",
      "event_data": {
        "status": "online",
        "db_status": "string",
        "uptime": "number",
        "launchTime": "ISO date",
        "userCount": "number",
        "courseCount": "number",
        "sessionCount": "number",
        "activeSessionCount": "number",
        "groupCount": "number",
        "assignmentCount": "number",
        "pendingSubmissionCount": "number",
        "upcomingMeetings": [{ "title": "string", "datetime": "ISO date", "durationMin": "number", "meetingLink": "string", "courseTitle": "string" }]
      }
    },
    "getLogs": {
      "method": "GET",
      "path": "/utils/logs",
      "access": "manage+",
      "query": {
        "date": "today | YYYY-MM-DD (optional, default today)",
        "lines": "number (optional, default 100)"
      },
      "response_200": { "date": "string", "logs": ["...log lines..."] }
    },
    "getLogFiles": {
      "method": "GET",
      "path": "/utils/logs/files",
      "access": "manage+",
      "response_200": { "files": ["app-YYYY-MM-DD.log"] }
    },
    "logsStream": {
      "method": "GET",
      "path": "/utils/logs/stream",
      "access": "token as query param",
      "query": {
        "token": "Bearer eyJ... (required)",
        "date": "today | YYYY-MM-DD (optional)",
        "lines": "number (optional)"
      },
      "note": "Server-Sent Events. Pushes latest log lines every 2 seconds."
    }
  },

  "DB": {
    "connect": {
      "method": "GET",
      "path": "/db/connect",
      "access": "admin+",
      "response_200": { "message": "Creating connection" }
    },
    "disconnect": {
      "method": "GET",
      "path": "/db/drop",
      "access": "admin+",
      "response_200": { "message": "Dropping connection" }
    }
  }
}
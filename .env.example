# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
#
#   cp .env.example .env
#
# Then run:
#   docker-compose up -d --build
# ═══════════════════════════════════════════════════════════════════════════════

# ── Your server's IP or domain ────────────────────────────────────────────────
# VPN testing:    SERVER_HOST=26.64.216.17   (your Radmin/Hamachi VPN IP)
# LAN testing:    SERVER_HOST=192.168.1.34   (your local network IP)
# Production:     SERVER_HOST=your-domain.com
SERVER_HOST=26.64.216.17

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# false = HTTP  (use for local/VPN testing — no cert needed)
# true  = HTTPS (requires a real domain + running init-ssl-cert.sh first)
USE_HTTPS=false

# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
DB_NAME=P_01
DB_URL=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# ── JWT & Security ────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
SECRET=your-app-secret-here

# ── EmailJS ───────────────────────────────────────────────────────────────────
REACT_APP_EMAILJS_PUBLIC_KEY=your-emailjs-key

# ── TURN server credentials ───────────────────────────────────────────────────
TURN_USERNAME=rtcuser
TURN_CREDENTIAL=changeme
